<!-- experience_letter.hbs -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #1a1a1a;
      font-size: 13px;
      line-height: 1.7;
      background: #fff;
    }
    .page { padding: 0; }

    /* ── Top accent bar ── */
    .top-bar { height: 8px; width: 100%; background: linear-gradient(90deg, #78350f, #f59e0b); }

    /* ── Header — float layout ── */
    .header {
      background: #fffbeb;
      padding: 16px 30px;
      border-bottom: 2px solid #fde68a;
      overflow: hidden;
    }
    .header-logo { float: left; }
    .header-logo img { max-height: 62px; max-width: 190px; display: block; }
    .header-logo .logo-text { font-size: 22px; font-weight: 700; color: #92400e; letter-spacing: 0.5px; }
    .header-company {
      float: right;
      text-align: right;
      font-size: 11px;
      color: #78716c;
      line-height: 1.55;
    }
    .header-company .company-name { font-size: 15px; font-weight: 700; color: #92400e; margin-bottom: 2px; }

    /* ── Body ── */
    .body { padding: 20px 30px; }

    /* ── Meta row — table layout ── */
    table.meta-table {
      width: 100%; border-collapse: collapse;
      margin-bottom: 16px; border-bottom: 1px dashed #fde68a;
      font-size: 11.5px; color: #78716c;
    }
    table.meta-table td { padding: 0 0 8px 0; border: none; background: none; }
    table.meta-table td:last-child { text-align: right; }

    /* ── Document title ── */
    .doc-title {
      text-align: center;
      background: #92400e;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 2px;
      padding: 9px 24px;
      border-radius: 30px;
      display: block;
      width: 100%;
      margin-bottom: 20px;
    }

    /* ── Text ── */
    .concern-line {
      font-weight: 700; font-size: 13.5px; color: #1c1917; margin-bottom: 14px; letter-spacing: 0.3px;
    }
    p { margin: 10px 0; text-align: justify; font-size: 13px; color: #1c1917; }

    /* ── Employment summary box ── */
    .summary-box {
      background: #fffbeb; border-left: 4px solid #d97706;
      border-radius: 0 6px 6px 0; padding: 14px 18px; margin: 22px 0;
    }
    .summary-box .box-heading {
      font-weight: 700; color: #92400e; font-size: 12.5px;
      margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    table.summary-table {
      width: 100%; border-collapse: collapse; font-size: 12px;
    }
    table.summary-table td { padding: 5px 8px; vertical-align: top; border: 1px solid #fde68a; }
    table.summary-table td.key {
      background: #fef3c7; font-weight: 600; color: #78350f; width: 36%;
    }
    table.summary-table td.val { color: #1c1917; background: #fffdf5; }
    table.summary-table tr:nth-child(even) td.val { background: #fffbeb; }

    /* ── Signature block ── */
    .signature-block { margin-top: 36px; text-align: right; }
    .signature-block img { max-height: 56px; max-width: 160px; display: block; margin-left: auto; margin-bottom: 4px; }
    .signature-block .sig-name { font-weight: 700; font-size: 13px; color: #1c1917; }
    .signature-block .sig-designation { font-size: 11.5px; color: #78716c; }
    .signature-block .sig-company { font-size: 11.5px; color: #92400e; font-weight: 600; }

    /* ── Footer ── */
    .footer {
      margin-top: 28px; border-top: 1px solid #fde68a; padding: 7px 30px;
      text-align: center; font-size: 10px; color: #92400e; background: #fffbeb; line-height: 1.5;
    }
  </style>
</head>
<body>
<div class="page">

  <div class="top-bar"></div>

  <!-- Header: logo left, company info right via float -->
  <div class="header">
    <div class="header-logo">
      {{#if company.logo_url}}
        <img src="{{company.logo_url}}" alt="{{company.name}}" />
      {{else}}
        <div class="logo-text">{{company.name}}</div>
      {{/if}}
    </div>
    <div class="header-company">
      <div class="company-name">{{company.name}}</div>
      <div>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}{{#if company.pincode}} - {{company.pincode}}{{/if}}</div>
      {{#if company.phone}}<div>Phone: {{company.phone}}</div>{{/if}}
      {{#if company.email}}<div>Email: {{company.email}}</div>{{/if}}
      {{#if company.website}}<div>{{company.website}}</div>{{/if}}
      {{#if company.gstin}}<div>GSTIN: {{company.gstin}}</div>{{/if}}
    </div>
  </div>

  <div class="body">

    <!-- Meta row: ref left, date right via table -->
    <table class="meta-table">
      <tr>
        <td><strong>Ref No:</strong> {{doc_number}}</td>
        <td><strong>Date:</strong> {{#if data.release_date}}{{data.release_date}}{{else}}{{today}}{{/if}}</td>
      </tr>
    </table>

    <div class="doc-title">EXPERIENCE CERTIFICATE</div>

    <div class="concern-line">TO WHOMSOEVER IT MAY CONCERN</div>

    <p>
      This is to certify that <strong>{{employee.full_name}}</strong> was employed with
      <strong>{{company.name}}</strong> from
      <strong>{{formatDate employee.date_of_joining "DD-MMM-YYYY"}}</strong> to
      <strong>{{formatDate employee.date_of_leaving "DD-MMM-YYYY"}}</strong>.
    </p>
    <p>
      During the tenure of his/her service with us, he/she held the position of
      <strong>{{employee.designation}}</strong> in the <strong>{{employee.department}}</strong> department,
      demonstrating competence and professionalism in carrying out the assigned responsibilities.
    </p>
    <p>
      {{#if data.summary}}
        {{data.summary}}
      {{else}}
        Throughout his/her association with the organization, we found
        <strong>{{employee.full_name}}</strong> to be sincere, hardworking, and dedicated
        towards his/her assigned responsibilities. His/her conduct, work ethic, and behaviour
        were consistently satisfactory during the entire period of employment.
      {{/if}}
    </p>
    <p>
      We wish him/her the very best in all future endeavours and have no hesitation in
      recommending him/her to prospective employers.
    </p>

    <!-- Employment summary box -->
    <div class="summary-box">
      <div class="box-heading">Employment Summary</div>
      <table class="summary-table">
        <tr>
          <td class="key">Employee Name</td>
          <td class="val">{{employee.full_name}}</td>
        </tr>
        <tr>
          <td class="key">Designation</td>
          <td class="val">{{employee.designation}}</td>
        </tr>
        <tr>
          <td class="key">Department</td>
          <td class="val">{{employee.department}}</td>
        </tr>
        <tr>
          <td class="key">Period of Service</td>
          <td class="val">{{formatDate employee.date_of_joining "DD-MMM-YYYY"}} &nbsp;to&nbsp; {{formatDate employee.date_of_leaving "DD-MMM-YYYY"}}</td>
        </tr>
        {{#if employee.employment_type}}
        <tr>
          <td class="key">Employment Type</td>
          <td class="val">{{employee.employment_type}}</td>
        </tr>
        {{/if}}
        {{#if employee.emp_code}}
        <tr>
          <td class="key">Employee Code</td>
          <td class="val">{{employee.emp_code}}</td>
        </tr>
        {{/if}}
      </table>
    </div>

    <div class="signature-block">
      <p style="font-size:12px; color:#78716c; margin-bottom:16px;">For <strong>{{company.name}}</strong>,</p>
      {{#if company.signature_url}}
        <img src="{{company.signature_url}}" alt="Signature" />
      {{/if}}
      {{#if company.stamp_url}}
        <img src="{{company.stamp_url}}" alt="Stamp" style="max-height:56px; max-width:56px; margin-left:auto; margin-bottom:4px; display:block;" />
      {{/if}}
      <div class="sig-name">{{company.signatory_name}}</div>
      <div class="sig-designation">{{company.signatory_designation}}</div>
      <div class="sig-company">{{company.name}}</div>
    </div>

  </div>

  <div class="footer">
    {{company.name}} &nbsp;|&nbsp; {{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}
    &nbsp;|&nbsp; {{company.email}}
    {{#if company.phone}}&nbsp;|&nbsp; {{company.phone}}{{/if}}
    &nbsp;|&nbsp; Doc No: {{doc_number}}
  </div>

</div>
</body>
</html>

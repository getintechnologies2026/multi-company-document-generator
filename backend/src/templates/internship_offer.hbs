<!-- internship_offer.hbs -->
<!DOCTYPE html>
<html><head><meta charset="utf-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; color: #1a1a1a; font-size: 13px; line-height: 1.7; }

  /* ── Top colour bar ── */
  .top-bar { height: 8px; background: linear-gradient(90deg, #7c2d12, #f97316); }

  /* ── Outer double-border frame ── */
  .frame { border: 3px double #c2410c; margin: 8px; padding: 4px; }
  .inner { border: 1px solid #fed7aa; padding: 20px 28px; }

  /* ── Header — float layout ── */
  .header {
    background: #fff7ed; border-bottom: 2px solid #fed7aa;
    padding: 12px 0 14px; margin-bottom: 20px; overflow: hidden;
  }
  .header .logo { float: left; }
  .header .logo img { max-height: 65px; max-width: 200px; display: block; }
  .header .logo .logo-text { font-size: 20px; font-weight: 700; color: #c2410c; }
  .header .company-info { float: right; text-align: right; font-size: 11px; color: #4b5563; }
  .header .company-info .cname { font-size: 16px; font-weight: 800; color: #c2410c; }

  /* ── Title band ── */
  .title-band { background: linear-gradient(90deg, #7c2d12, #f97316); color: #fff; text-align: center; padding: 16px 0 12px; border-radius: 8px; margin-bottom: 22px; }
  .title-band .t-main { font-size: 22px; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; }
  .title-band .t-sub  { font-size: 11px; letter-spacing: 2px; opacity: 0.88; margin-top: 4px; }

  /* ── Ref row — table layout ── */
  table.ref-table {
    width: 100%; border-collapse: collapse;
    margin-bottom: 18px; font-size: 11px; color: #6b7280;
  }
  table.ref-table td { border: none; background: none; padding: 0; }
  table.ref-table td:last-child { text-align: right; }

  /* ── Addressee block ── */
  .addr-block { font-size: 12.5px; color: #374151; margin-bottom: 16px; line-height: 1.75; }
  .addr-block .salute { font-size: 13.5px; font-weight: 700; margin-top: 10px; color: #1a1a1a; }

  /* ── Body text ── */
  .body-text { font-size: 13.5px; line-height: 1.9; text-align: justify; margin-bottom: 14px; }
  .body-text strong { color: #7c2d12; }

  /* ── Details table ── */
  .detail-table { width: 100%; border-collapse: collapse; margin: 14px 0; }
  .detail-table td { padding: 7px 12px; font-size: 12px; border: 1px solid #fed7aa; }
  .detail-table tr:nth-child(even) td { background: #fff7ed; }
  .detail-table td:first-child { font-weight: 700; color: #c2410c; width: 38%; background: #ffedd5; }

  /* ── Terms box ── */
  .terms-box { background: #fff7ed; border-left: 4px solid #f97316; border-radius: 6px; padding: 12px 16px; margin: 14px 0; font-size: 12px; color: #374151; }
  .terms-box strong { color: #c2410c; }
  .terms-box ul { margin: 6px 0 2px; padding-left: 18px; }
  .terms-box li { margin-bottom: 4px; line-height: 1.6; }

  /* ── Signature section — float layout ── */
  .sig-section { margin-top: 40px; padding-top: 32px; overflow: hidden; }
  .seal-block { float: left; text-align: center; }
  .seal-block img { max-height: 70px; display: block; }
  .seal-text { font-size: 10px; color: #9ca3af; margin-top: 4px; }
  .seal-placeholder {
    width: 80px; height: 80px; border: 2px dashed #fed7aa; border-radius: 50%;
    text-align: center; padding-top: 24px;
    font-size: 9px; color: #f97316; display: inline-block;
  }
  .sig-block { float: right; text-align: center; min-width: 180px; }
  .sig-block img { max-height: 55px; margin-bottom: 4px; display: block; margin-left: auto; margin-right: auto; }
  .sig-line { border-top: 1.5px solid #374151; padding-top: 6px; margin-top: 6px; }
  .sig-name  { font-weight: 700; font-size: 13px; }
  .sig-title { font-size: 11px; color: #6b7280; }

  /* ── Acceptance block ── */
  .accept-block { margin-top: 22px; border: 1.5px dashed #f97316; border-radius: 8px; padding: 14px 18px; font-size: 12px; color: #374151; background: #fff7ed; }
  .accept-title { font-weight: 800; color: #c2410c; font-size: 12.5px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }

  /* ── Sign row — table layout ── */
  table.sign-table {
    width: 100%; border-collapse: collapse; margin-top: 28px; font-size: 10px; color: #6b7280;
  }
  table.sign-table td {
    border: none; background: none; padding-top: 4px;
    border-top: 1px solid #9ca3af; text-align: center;
  }

  /* ── Footer ── */
  .footer { margin-top: 20px; border-top: 2px solid #fed7aa; padding-top: 8px; text-align: center; font-size: 10px; color: #9ca3af; }
  .footer strong { color: #c2410c; }
</style>
</head>
<body>

<div class="top-bar"></div>

<div class="frame">
<div class="inner">

  <!-- Header: logo left, company info right via float -->
  <div class="header">
    <div class="logo">
      {{#if company.logo_url}}
        <img src="{{company.logo_url}}" alt="{{company.name}}" />
      {{else}}
        <div class="logo-text">{{company.name}}</div>
      {{/if}}
    </div>
    <div class="company-info">
      <div class="cname">{{company.name}}</div>
      <div>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}</div>
      <div>{{company.email}} | {{company.phone}}</div>
      {{#if company.website}}<div>{{company.website}}</div>{{/if}}
    </div>
  </div>

  <!-- Title Band -->
  <div class="title-band">
    <div class="t-main">Internship Offer Letter</div>
    <div class="t-sub">Official Offer for Internship Programme</div>
  </div>

  <!-- Ref Row: ref left, date right via table -->
  <table class="ref-table">
    <tr>
      <td>Ref No: <strong>{{doc_number}}</strong></td>
      <td>Date: <strong>{{data.issue_date}}</strong></td>
    </tr>
  </table>

  <!-- Addressee Block -->
  <div class="addr-block">
    <strong>To,</strong><br>
    <strong>{{data.intern_name}}</strong><br>
    {{#if data.roll_no}}<span>Roll No: {{data.roll_no}}</span><br>{{/if}}
    {{#if data.college}}{{data.college}}{{/if}}
    {{#if data.course}}<br>{{data.course}}{{#if data.branch}} ({{data.branch}}){{/if}}{{/if}}
    <div class="salute">Dear {{data.intern_name}},</div>
  </div>

  <!-- Opening Para -->
  <div class="body-text">
    <p>
      We are pleased to offer you an internship at <strong>{{company.name}}</strong>{{#if data.department}}
      in the <strong>{{data.department}}</strong> department{{/if}}. We were impressed with your profile
      and believe you will make a valuable contribution to our team during your time with us.
    </p>
    <p>
      Your internship is scheduled to commence on <strong>{{data.from_date}}</strong> and conclude on
      <strong>{{data.to_date}}</strong>{{#if data.duration_text}} ({{data.duration_text}}){{/if}}.
      Please find the complete details of your internship offer below.
    </p>
  </div>

  <!-- Details Table -->
  <table class="detail-table">
    <tr><td>Intern Name</td><td><strong>{{data.intern_name}}</strong></td></tr>
    {{#if data.roll_no}}<tr><td>Roll No / Register No</td><td>{{data.roll_no}}</td></tr>{{/if}}
    {{#if data.college}}<tr><td>Institution</td><td>{{data.college}}</td></tr>{{/if}}
    {{#if data.course}}<tr><td>Course / Degree</td><td>{{data.course}}{{#if data.branch}} &mdash; {{data.branch}}{{/if}}</td></tr>{{/if}}
    <tr><td>Department / Domain</td><td>{{data.department}}</td></tr>
    {{#if data.project_title}}<tr><td>Project / Role</td><td>{{data.project_title}}</td></tr>{{/if}}
    <tr><td>Internship Start Date</td><td><strong>{{data.from_date}}</strong></td></tr>
    <tr><td>Internship End Date</td><td><strong>{{data.to_date}}</strong></td></tr>
    <tr><td>Duration</td><td>{{data.duration_text}}</td></tr>
    {{#if data.stipend}}<tr><td>Monthly Stipend</td><td><strong>&#8377;{{data.stipend}}</strong> per month</td></tr>{{/if}}
    {{#if data.mentor_name}}<tr><td>Reporting To</td><td>{{data.mentor_name}}</td></tr>{{/if}}
    <tr><td>Work Location</td><td>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}</td></tr>
  </table>

  <!-- Terms Box -->
  <div class="terms-box">
    <strong>Terms &amp; Conditions:</strong>
    <ul>
      <li>This internship is offered for academic / training purposes and does not constitute an employment relationship.</li>
      <li>You are expected to maintain professional conduct and adhere to all company policies and guidelines throughout the internship period.</li>
      <li>Either party may terminate this internship arrangement by giving reasonable prior written notice.</li>
      {{#if data.joining_instructions}}<li>{{data.joining_instructions}}</li>{{/if}}
      <li>Confidentiality of company information and proprietary data must be strictly maintained.</li>
    </ul>
  </div>

  <!-- Closing Para -->
  <div class="body-text">
    <p>
      We look forward to welcoming you to <strong>{{company.name}}</strong> and are confident this internship
      will be a rewarding and enriching experience for you. Please confirm your acceptance of this offer by
      signing the duplicate copy of this letter and returning it to us at the earliest convenience.
    </p>
  </div>

  <!-- Signature Section: seal left, sig right via float -->
  <div class="sig-section">
    <div class="seal-block">
      {{#if company.stamp_url}}
        <img src="{{company.stamp_url}}" alt="Company Seal" />
        <div class="seal-text">Company Seal</div>
      {{else}}
        <div class="seal-placeholder">Company<br>Seal</div>
      {{/if}}
    </div>
    <div class="sig-block">
      {{#if company.signature_url}}<img src="{{company.signature_url}}" alt="Signature" />{{/if}}
      <div class="sig-line">
        <div class="sig-name">{{company.signatory_name}}</div>
        <div class="sig-title">{{company.signatory_designation}}</div>
        <div class="sig-title">{{company.name}}</div>
      </div>
    </div>
  </div>

  <!-- Acceptance Block -->
  <div class="accept-block">
    <div class="accept-title">Acceptance by Intern</div>
    <p style="margin: 0; font-size: 12px;">
      I, <strong>{{data.intern_name}}</strong>, hereby accept the internship offer extended by
      <strong>{{company.name}}</strong> and agree to abide by all the terms and conditions mentioned above.
    </p>
    <!-- Sign row: three equal columns via table -->
    <table class="sign-table">
      <tr>
        <td>Intern Signature</td>
        <td>Place</td>
        <td>Date</td>
      </tr>
    </table>
  </div>

  <!-- Footer -->
  <div class="footer">
    <strong>{{company.name}}</strong> &nbsp;|&nbsp; {{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}} &nbsp;|&nbsp;
    {{company.email}} &nbsp;|&nbsp; {{company.phone}}
  </div>

</div>
</div>

</body></html>

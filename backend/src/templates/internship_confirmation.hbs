<!DOCTYPE html>
<html><head><meta charset="utf-8">
<style>
  * { box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; color: #1a1a1a; font-size: 13px; line-height: 1.7; margin: 0; padding: 0; }

  /* ── Top colour bar ── */
  .top-bar { height: 8px; background: linear-gradient(90deg, #134e4a, #2dd4bf); }

  /* ── Outer double-border frame ── */
  .frame { border: 3px double #0f766e; margin: 8px; padding: 4px; min-height: calc(100vh - 24px); display: -webkit-box; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; }

  /* ── Inner single-border ── */
  .inner { border: 1px solid #99f6e4; padding: 20px 28px; -webkit-box-flex: 1; flex: 1; display: -webkit-box; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; }

  /* ── Header ── */
  .header { display: -webkit-box; display: flex; -webkit-box-pack: justify; justify-content: space-between; -webkit-box-align: center; align-items: center; background: #f0fdfa; border-bottom: 2px solid #99f6e4; padding: 12px 0 14px; margin-bottom: 20px; }
  .header .logo img { max-height: 65px; max-width: 200px; }
  .header .logo .logo-text { font-size: 20px; font-weight: 700; color: #0f766e; }
  .header .company-info { text-align: right; font-size: 11px; color: #4b5563; }
  .header .company-info .cname { font-size: 16px; font-weight: 800; color: #0f766e; }

  /* ── Title band ── */
  .title-band { background: linear-gradient(90deg, #134e4a, #2dd4bf); color: #fff; text-align: center; padding: 16px 0 12px; border-radius: 8px; margin-bottom: 22px; }
  .title-band .t-main { font-size: 22px; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; }
  .title-band .t-sub  { font-size: 11px; letter-spacing: 2px; opacity: 0.88; margin-top: 4px; }

  /* ── Ref row ── */
  .ref-row { display: -webkit-box; display: flex; -webkit-box-pack: justify; justify-content: space-between; font-size: 11px; color: #6b7280; margin-bottom: 18px; }

  /* ── Addressee block ── */
  .addr-block { font-size: 12.5px; color: #374151; margin-bottom: 16px; line-height: 1.75; }
  .addr-block .salute { font-size: 13.5px; font-weight: 700; margin-top: 10px; color: #1a1a1a; }

  /* ── Body text ── */
  .body-text { font-size: 13.5px; line-height: 1.9; text-align: justify; margin-bottom: 14px; }
  .body-text strong { color: #134e4a; }
  .highlight-name { font-size: 16px; font-weight: 700; color: #0f766e; }

  /* ── Details table ── */
  .detail-table { width: 100%; border-collapse: collapse; margin: 14px 0; }
  .detail-table td { padding: 7px 12px; font-size: 12px; border: 1px solid #99f6e4; }
  .detail-table tr:nth-child(even) td { background: #f0fdfa; }
  .detail-table td:first-child { font-weight: 700; color: #0f766e; width: 38%; background: #ccfbf1; }

  /* ── Joining instructions box ── */
  .join-box { background: #f0fdfa; border-left: 4px solid #2dd4bf; border-radius: 6px; padding: 12px 16px; margin: 14px 0; font-size: 12px; color: #374151; }
  .join-box .join-title { font-weight: 800; color: #0f766e; font-size: 12.5px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
  .join-box ul { margin: 6px 0 2px; padding-left: 18px; }
  .join-box li { margin-bottom: 4px; line-height: 1.6; }

  /* ── Signature ── */
  .sig-section { margin-top: auto; padding-top: 32px; display: -webkit-box; display: flex; -webkit-box-pack: justify; justify-content: space-between; -webkit-box-align: end; align-items: flex-end; }
  .sig-block { text-align: center; min-width: 180px; }
  .sig-block img { max-height: 55px; margin-bottom: 4px; }
  .sig-line { border-top: 1.5px solid #374151; padding-top: 6px; margin-top: 6px; }
  .sig-name  { font-weight: 700; font-size: 13px; }
  .sig-title { font-size: 11px; color: #6b7280; }
  .seal-block { text-align: center; }
  .seal-block img { max-height: 70px; }
  .seal-text { font-size: 10px; color: #9ca3af; margin-top: 4px; }
  .seal-placeholder { width: 80px; height: 80px; border: 2px dashed #99f6e4; border-radius: 50%; display: -webkit-box; display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: center; justify-content: center; font-size: 9px; color: #2dd4bf; text-align: center; padding: 8px; }

  /* ── Footer ── */
  .footer { margin-top: 20px; border-top: 2px solid #99f6e4; padding-top: 8px; text-align: center; font-size: 10px; color: #9ca3af; }
  .footer strong { color: #0f766e; }
</style>
</head>
<body>

<div class="top-bar"></div>

<div class="frame">
<div class="inner">

  <!-- Header -->
  <div class="header">
    <div class="logo">
      {{#if company.logo_url}}
        <img src="{{company.logo_url}}" alt="{{company.name}}" />
      {{else}}
        <div class="logo-text">{{company.name}}</div>
      {{/if}}
    </div>
    <div class="company-info">
      <div class="cname">{{company.name}}</div>
      <div>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}</div>
      <div>{{company.email}} | {{company.phone}}</div>
      {{#if company.website}}<div>{{company.website}}</div>{{/if}}
    </div>
  </div>

  <!-- Title Band -->
  <div class="title-band">
    <div class="t-main">Internship Joining Confirmation</div>
    <div class="t-sub">Confirmation of Internship Commencement</div>
  </div>

  <!-- Ref Row -->
  <div class="ref-row">
    <span>Ref No: <strong>{{doc_number}}</strong></span>
    <span>Date: <strong>{{data.issue_date}}</strong></span>
  </div>

  <!-- Addressee Block -->
  <div class="addr-block">
    <strong>To,</strong><br>
    <strong>{{data.intern_name}}</strong><br>
    {{#if data.roll_no}}<span>Roll No: {{data.roll_no}}</span><br>{{/if}}
    {{#if data.college}}{{data.college}}{{/if}}
    {{#if data.course}}<br>{{data.course}}{{#if data.branch}} ({{data.branch}}){{/if}}{{/if}}
  </div>

  <!-- Salutation -->
  <div style="font-size:13.5px; font-weight:700; margin-bottom:14px;">Dear {{data.intern_name}},</div>

  <!-- Opening -->
  <div class="body-text">
    <p>
      We are pleased to confirm your joining for the internship programme at <strong>{{company.name}}</strong>{{#if data.department}}
      in the <strong>{{data.department}}</strong> department{{/if}}. This letter serves as the official confirmation
      of your internship commencement.
    </p>
    <p>
      Your internship period is from <strong>{{data.from_date}}</strong> to <strong>{{data.to_date}}</strong>{{#if data.duration_text}} ({{data.duration_text}}){{/if}}.
      We are delighted to have you with us and look forward to a mutually productive experience.
    </p>
  </div>

  <!-- Details Table -->
  <table class="detail-table">
    <tr><td>Intern Name</td><td><strong>{{data.intern_name}}</strong></td></tr>
    {{#if data.roll_no}}<tr><td>Roll No / Register No</td><td>{{data.roll_no}}</td></tr>{{/if}}
    {{#if data.college}}<tr><td>Institution</td><td>{{data.college}}</td></tr>{{/if}}
    {{#if data.course}}<tr><td>Course / Degree</td><td>{{data.course}}{{#if data.branch}} &mdash; {{data.branch}}{{/if}}</td></tr>{{/if}}
    <tr><td>Department / Domain</td><td>{{data.department}}</td></tr>
    {{#if data.project_title}}<tr><td>Project / Role</td><td>{{data.project_title}}</td></tr>{{/if}}
    <tr><td>Date of Joining</td><td><strong>{{#if data.joining_date}}{{data.joining_date}}{{else}}{{data.from_date}}{{/if}}</strong></td></tr>
    <tr><td>Internship End Date</td><td><strong>{{data.to_date}}</strong></td></tr>
    <tr><td>Duration</td><td>{{data.duration_text}}</td></tr>
    {{#if data.stipend}}<tr><td>Monthly Stipend</td><td><strong>&#8377;{{data.stipend}}</strong> per month</td></tr>{{/if}}
    <tr><td>Reporting To / Supervisor</td><td>
      {{#if data.supervisor}}{{data.supervisor}}{{else}}{{#if data.mentor_name}}{{data.mentor_name}}{{else}}&mdash;{{/if}}{{/if}}
    </td></tr>
    <tr><td>Work Location</td><td>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}</td></tr>
  </table>

  <!-- Joining Instructions Box -->
  <div class="join-box">
    <div class="join-title">Joining Instructions</div>
    <ul>
      <li>Please report on your joining date at <strong>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}</strong> during regular office hours.</li>
      <li>Bring originals (along with photocopies) of: valid Government-issued ID proof, college ID card / bonafide letter, recent passport-size photographs, and any other documents requested.</li>
      <li>Ensure you have read and understood the company's code of conduct and confidentiality guidelines before reporting.</li>
      <li>Contact <strong>{{company.email}}</strong> or <strong>{{company.phone}}</strong> for any pre-joining queries.</li>
    </ul>
  </div>

  <!-- Closing Para -->
  <div class="body-text">
    <p>
      We look forward to welcoming you to the <strong>{{company.name}}</strong> team. This internship is an
      excellent opportunity for learning and professional growth, and we hope you will make the most of it.
      This letter is issued for official and academic record purposes.
    </p>
  </div>

  <!-- Signature Section -->
  <div class="sig-section">
    <div class="seal-block">
      {{#if company.stamp_url}}
        <img src="{{company.stamp_url}}" alt="Company Seal" />
        <div class="seal-text">Company Seal</div>
      {{else}}
        <div class="seal-placeholder">Company<br>Seal</div>
      {{/if}}
    </div>
    <div class="sig-block">
      {{#if company.signature_url}}<img src="{{company.signature_url}}" alt="Signature" />{{/if}}
      <div class="sig-line">
        <div class="sig-name">{{company.signatory_name}}</div>
        <div class="sig-title">{{company.signatory_designation}}</div>
        <div class="sig-title">{{company.name}}</div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="footer">
    <strong>{{company.name}}</strong> &nbsp;|&nbsp; {{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}} &nbsp;|&nbsp;
    {{company.email}} &nbsp;|&nbsp; {{company.phone}}
  </div>

</div><!-- /.inner -->
</div><!-- /.frame -->

</body></html>

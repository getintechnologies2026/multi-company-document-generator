<!-- offer_letter.hbs — 4-page comprehensive offer letter -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    /* ── Reset ── */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #1a1a1a;
      font-size: 12.5px;
      line-height: 1.7;
      background: #fff;
    }

    /* ── Page break ── */
    .page-break { page-break-after: always; }

    /* ── Top accent bar ── */
    .top-bar { height: 8px; width: 100%; background: linear-gradient(90deg, #1e3a8a, #3b82f6); }

    /* ── Header — float layout ── */
    .header {
      background: #eff6ff;
      padding: 14px 30px;
      border-bottom: 2px solid #bfdbfe;
      overflow: hidden;
    }
    .header-logo { float: left; }
    .header-logo img { max-height: 60px; max-width: 185px; display: block; }
    .header-logo .logo-text { font-size: 21px; font-weight: 700; color: #1e40af; letter-spacing: 0.5px; }
    .header-company {
      float: right; text-align: right; font-size: 10.5px; color: #475569; line-height: 1.55;
    }
    .header-company .company-name { font-size: 14px; font-weight: 700; color: #1e40af; margin-bottom: 2px; }

    /* ── Body ── */
    .body { padding: 18px 30px 10px; }

    /* ── Confidential banner ── */
    .confidential-bar {
      text-align: center; font-size: 9.5px; font-weight: 700;
      letter-spacing: 3px; color: #dc2626; text-transform: uppercase;
      margin-bottom: 8px; opacity: 0.75;
    }

    /* ── Meta row — table layout ── */
    table.meta-table {
      width: 100%; border-collapse: collapse;
      margin-bottom: 12px; border-bottom: 1px dashed #bfdbfe;
      font-size: 11px; color: #475569;
    }
    table.meta-table td { padding: 0 0 7px 0; border: none; background: none; }
    table.meta-table td:last-child { text-align: right; }

    /* ── Document title ── */
    .doc-title {
      text-align: center; background: #1e40af; color: #fff;
      font-size: 15px; font-weight: 700; letter-spacing: 3px;
      padding: 10px 24px; border-radius: 30px;
      display: block; width: 100%; margin-bottom: 16px;
    }

    /* ── Candidate address block ── */
    .addr-block {
      background: #f8faff; border-left: 3px solid #bfdbfe;
      padding: 10px 14px; margin-bottom: 14px;
      font-size: 12px; color: #1e293b; line-height: 1.8;
    }
    .addr-block .addr-name { font-size: 13px; font-weight: 700; color: #1e40af; }

    /* ── Subject line ── */
    .subject-line {
      font-size: 12.5px; font-weight: 700; color: #1e293b;
      margin: 10px 0 12px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;
    }
    .subject-line span { color: #1e40af; }

    /* ── Salutation & paragraphs ── */
    .salutation { font-size: 13px; margin-bottom: 8px; }
    p { margin: 7px 0; text-align: justify; font-size: 12.5px; color: #1c1917; }

    /* ── Section heading ── */
    .section-heading {
      font-size: 12px; font-weight: 700; color: #1e40af;
      margin: 16px 0 6px; text-transform: uppercase; letter-spacing: 1px;
      border-left: 4px solid #3b82f6; padding-left: 8px;
    }

    /* ── Section heading (page 3 style — numbered) ── */
    .tc-heading {
      font-size: 13px; font-weight: 800; color: #1e3a8a;
      margin: 0 0 8px; text-transform: uppercase; letter-spacing: 1.5px;
      text-align: center; border-bottom: 2px solid #bfdbfe; padding-bottom: 6px;
    }

    /* ── Employment details table ── */
    table.details-table {
      width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 12px;
    }
    table.details-table th {
      background: #1e40af; color: #fff; padding: 7px 10px;
      text-align: left; font-weight: 600; font-size: 11.5px;
    }
    table.details-table td { border: 1px solid #bfdbfe; padding: 6px 10px; vertical-align: top; }
    table.details-table td:first-child { width: 42%; background: #eff6ff; font-weight: 600; color: #1e3a8a; }
    table.details-table tr:nth-child(even) td:last-child { background: #f8fafc; }
    table.details-table td strong { color: #1e40af; }

    /* ── Salary table ── */
    table.salary-table {
      width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 11.5px;
    }
    table.salary-table th {
      padding: 7px 10px; text-align: left; font-weight: 700; border: 1px solid #bfdbfe; font-size: 11px;
    }
    table.salary-table th.th-blue { background: #1e40af; color: #fff; }
    table.salary-table th.th-light { background: #dbeafe; color: #1e3a8a; text-align: right; }
    table.salary-table td { border: 1px solid #bfdbfe; padding: 6px 10px; vertical-align: middle; }
    table.salary-table td:first-child { background: #f8faff; font-weight: 500; color: #334155; width: 50%; }
    table.salary-table td.amount { text-align: right; color: #1e293b; }
    table.salary-table td.annual { text-align: right; color: #1e3a8a; font-weight: 600; }
    table.salary-table tr:nth-child(even) td:first-child { background: #eff6ff; }
    table.salary-table tr.gross-row td {
      background: #dbeafe; font-weight: 700; color: #1e3a8a; border-top: 2px solid #3b82f6;
    }
    table.salary-table tr.deduction-row td:first-child { color: #dc2626; }
    table.salary-table tr.deduction-row td { background: #fef2f2 !important; }
    table.salary-table tr.net-row td {
      background: #1e40af; color: #fff; font-weight: 700; font-size: 13px; border-top: 2px solid #1e3a8a;
    }
    table.salary-table tr.net-row td.amount { color: #fff; }
    table.salary-table tr.ctc-row td {
      background: #1e3a8a; color: #fff; font-weight: 700; font-size: 12px;
    }
    table.salary-table tr.ctc-row td.amount { color: #93c5fd; }

    /* ── Benefits box ── */
    .benefits-box {
      background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 6px;
      padding: 12px 16px; margin: 14px 0;
    }
    .benefits-box .ben-title {
      font-size: 11.5px; font-weight: 700; color: #0369a1; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    table.ben-table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
    table.ben-table td { padding: 4px 8px; vertical-align: top; width: 50%; color: #1e293b; }
    table.ben-table td:before { content: "✔ "; color: #2563eb; font-size: 10px; }

    /* ── Leave table ── */
    table.leave-table {
      width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 11.5px;
    }
    table.leave-table th {
      background: #1e40af; color: #fff; padding: 7px 10px; text-align: left; font-size: 11px; font-weight: 600;
    }
    table.leave-table td { border: 1px solid #bfdbfe; padding: 6px 10px; }
    table.leave-table td:first-child { background: #eff6ff; font-weight: 600; color: #1e3a8a; width: 45%; }
    table.leave-table td:nth-child(2) { text-align: center; font-weight: 700; color: #1e40af; width: 20%; }
    table.leave-table tr:nth-child(even) td:last-child { background: #f8fafc; }

    /* ── T&C numbered clauses ── */
    .tc-block {
      margin-bottom: 10px;
    }
    .tc-clause-title {
      font-size: 11.5px; font-weight: 700; color: #1e3a8a;
      margin-bottom: 4px;
    }
    .tc-clause-title .clause-num {
      display: inline-block; background: #1e40af; color: #fff;
      border-radius: 50%; width: 20px; height: 20px;
      text-align: center; line-height: 20px; font-size: 10.5px;
      margin-right: 6px; font-weight: 800;
    }
    .tc-clause-body {
      font-size: 11.5px; color: #334155; line-height: 1.65;
      text-align: justify; padding-left: 26px;
    }
    .tc-clause-body ul { padding-left: 14px; margin: 4px 0; }
    .tc-clause-body ul li { margin-bottom: 3px; }

    /* ── Important note box ── */
    .note-box {
      background: #fef3c7; border-left: 4px solid #f59e0b;
      border-radius: 0 6px 6px 0; padding: 10px 14px; margin: 14px 0; font-size: 11.5px;
    }
    .note-box strong { color: #92400e; }

    /* ── Acceptance section ── */
    .acceptance-box {
      background: #f0fdf4; border: 1.5px dashed #22c55e;
      border-radius: 8px; padding: 16px 20px; margin-top: 20px;
    }
    .acceptance-box .acc-title {
      font-size: 12.5px; font-weight: 800; color: #166534;
      text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;
      text-align: center; border-bottom: 1px solid #bbf7d0; padding-bottom: 8px;
    }
    .acceptance-box p { font-size: 11.5px; color: #374151; margin: 6px 0; text-align: justify; }
    table.acc-fields {
      width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 11px; color: #6b7280;
    }
    table.acc-fields td {
      border: none; background: none; padding: 0;
      border-top: 1px solid #374151; padding-top: 5px; text-align: left; width: 33.33%;
    }
    table.acc-fields td:nth-child(2) { text-align: center; }
    table.acc-fields td:last-child { text-align: right; }

    /* ── Signature block ── */
    .signature-block { margin-top: 28px; text-align: right; }
    .signature-block img { max-height: 56px; max-width: 160px; display: block; margin-left: auto; margin-bottom: 4px; }
    .signature-block .sig-name { font-weight: 700; font-size: 13px; color: #1e293b; }
    .signature-block .sig-designation { font-size: 11px; color: #475569; }
    .signature-block .sig-company { font-size: 11px; color: #1e40af; font-weight: 600; }

    /* ── Footer ── */
    .footer {
      margin-top: 14px; border-top: 1px solid #bfdbfe; padding: 6px 30px;
      text-align: center; font-size: 9.5px; color: #64748b; background: #f8faff; line-height: 1.5;
    }

    /* ── Page header repeated (pages 2-4) ── */
    .page-header {
      background: #1e40af; color: #fff;
      padding: 6px 30px; overflow: hidden; font-size: 10.5px;
    }
    .page-header .ph-left { float: left; font-weight: 600; }
    .page-header .ph-right { float: right; opacity: 0.85; }

    /* ── Two-column grid using table ── */
    table.two-col { width: 100%; border-collapse: collapse; }
    table.two-col td { vertical-align: top; width: 50%; padding: 0 8px 0 0; border: none; background: none; }
    table.two-col td:last-child { padding: 0 0 0 8px; }
  </style>
</head>
<body>

<!-- ════════════════════════════════════════════════════════════
     PAGE 1 — OFFER DETAILS & EMPLOYMENT TERMS
     ════════════════════════════════════════════════════════════ -->

<div class="top-bar"></div>

<div class="header">
  <div class="header-logo">
    {{#if company.logo_url}}
      <img src="{{company.logo_url}}" alt="{{company.name}}" />
    {{else}}
      <div class="logo-text">{{company.name}}</div>
    {{/if}}
  </div>
  <div class="header-company">
    <div class="company-name">{{company.name}}</div>
    <div>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}{{#if company.pincode}} &mdash; {{company.pincode}}{{/if}}</div>
    {{#if company.phone}}<div>Phone: {{company.phone}}</div>{{/if}}
    {{#if company.email}}<div>Email: {{company.email}}</div>{{/if}}
    {{#if company.website}}<div>{{company.website}}</div>{{/if}}
    {{#if company.gstin}}<div>GSTIN: {{company.gstin}}</div>{{/if}}
  </div>
</div>

<div class="body">

  <div class="confidential-bar">— Private &amp; Confidential —</div>

  <table class="meta-table">
    <tr>
      <td><strong>Ref No:</strong> {{doc_number}}</td>
      <td><strong>Date:</strong> {{today}}</td>
    </tr>
  </table>

  <div class="doc-title">LETTER OF APPOINTMENT / OFFER OF EMPLOYMENT</div>

  <!-- Candidate address -->
  <div class="addr-block">
    <div class="addr-name">{{employee.full_name}}</div>
    {{#if employee.address}}<div>{{employee.address}}</div>{{/if}}
    {{#if employee.email}}<div>Email: {{employee.email}}{{#if employee.mobile}} &nbsp;|&nbsp; Mobile: {{employee.mobile}}{{/if}}</div>{{/if}}
  </div>

  <div class="subject-line">
    Subject: <span>Letter of Appointment for the Position of {{#if employee.offered_designation}}{{employee.offered_designation}}{{else}}{{employee.designation}}{{/if}}</span>
  </div>

  <p class="salutation">Dear <strong>{{employee.full_name}}</strong>,</p>

  <p>
    We are pleased to inform you that after a careful review of your application and interview,
    <strong>{{company.name}}</strong> is delighted to offer you the position of
    <strong>{{#if employee.offered_designation}}{{employee.offered_designation}}{{else}}{{employee.designation}}{{/if}}</strong>
    in the <strong>{{employee.department}}</strong> department. We believe your skills, experience,
    and professional conduct are well-suited for this role, and we look forward to your valuable
    contribution to our organisation.
  </p>
  <p>
    This letter sets out the terms and conditions of your employment with us. Please read all clauses
    carefully before signing and returning the acceptance copy.
  </p>

  <!-- Employment details table -->
  <div class="section-heading">Employment Details</div>
  <table class="details-table">
    <tr><th colspan="2">Appointment Particulars</th></tr>
    <tr>
      <td>Employee Name</td>
      <td><strong>{{employee.full_name}}</strong></td>
    </tr>
    <tr>
      <td>Designation</td>
      <td><strong>{{#if employee.offered_designation}}{{employee.offered_designation}}{{else}}{{employee.designation}}{{/if}}</strong></td>
    </tr>
    <tr>
      <td>Department</td>
      <td>{{employee.department}}</td>
    </tr>
    <tr>
      <td>Date of Joining</td>
      <td><strong>{{#if employee.joining_date}}{{formatDate employee.joining_date "DD-MMM-YYYY"}}{{else}}{{formatDate employee.date_of_joining "DD-MMM-YYYY"}}{{/if}}</strong></td>
    </tr>
    <tr>
      <td>Employment Type</td>
      <td>{{employee.employment_type}}</td>
    </tr>
    <tr>
      <td>Work Location</td>
      <td>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}}{{#if company.state}}, {{company.state}}{{/if}}</td>
    </tr>
    <tr>
      <td>Reporting To</td>
      <td>{{#if employee.reporting_to}}{{employee.reporting_to}}{{else}}Respective Functional Head{{/if}}</td>
    </tr>
    <tr>
      <td>Probation Period</td>
      <td><strong>Six (6) Months</strong> from the Date of Joining</td>
    </tr>
    <tr>
      <td>Notice Period</td>
      <td><strong>One (1) Month</strong> (during probation) &nbsp;|&nbsp; <strong>One (1) Month</strong> (post-confirmation)</td>
    </tr>
    <tr>
      <td>Annual CTC (Cost to Company)</td>
      <td><strong>&#8377; {{#if employee.offered_ctc}}{{inr employee.offered_ctc}}{{else}}{{inr employee.ctc}}{{/if}} /- per annum</strong></td>
    </tr>
    {{#if employee.pan}}
    <tr>
      <td>PAN</td>
      <td>{{employee.pan}}</td>
    </tr>
    {{/if}}
  </table>

</div>

<div class="footer">
  {{company.name}} &nbsp;|&nbsp; {{company.address}}{{#if company.city}}, {{company.city}}{{/if}} &nbsp;|&nbsp; {{company.email}} &nbsp;|&nbsp; Doc No: {{doc_number}} &nbsp;|&nbsp; <strong>Page 1 of 4</strong>
</div>

<!-- ════════════ PAGE BREAK ════════════ -->
<div class="page-break"></div>

<!-- ════════════════════════════════════════════════════════════
     PAGE 2 — COMPENSATION, BENEFITS & LEAVE POLICY
     ════════════════════════════════════════════════════════════ -->

<div class="top-bar"></div>
<div class="page-header">
  <div class="ph-left">{{company.name}} &nbsp;&mdash;&nbsp; Letter of Appointment</div>
  <div class="ph-right">{{employee.full_name}} &nbsp;|&nbsp; {{today}}</div>
</div>

<div class="body">

  <div class="section-heading">Compensation &amp; Salary Breakdown</div>

  <p>Your gross monthly remuneration and the annual CTC breakup are detailed below. This is a
  cost-to-company (CTC) structure and the in-hand take-home will vary based on applicable
  statutory deductions.</p>

  <table class="salary-table">
    <tr>
      <th class="th-blue" style="width:50%">Salary Component</th>
      <th class="th-light" style="width:25%">Monthly (&#8377;)</th>
      <th class="th-light" style="width:25%">Annual (&#8377;)</th>
    </tr>
    <!-- Earnings -->
    {{#if employee.basic}}
    <tr>
      <td>Basic Salary</td>
      <td class="amount">{{inr employee.basic}}</td>
      <td class="annual">{{inr employee.basic_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.hra}}
    <tr>
      <td>House Rent Allowance (HRA) &mdash; 50% of Basic</td>
      <td class="amount">{{inr employee.hra}}</td>
      <td class="annual">{{inr employee.hra_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.da}}
    <tr>
      <td>Dearness Allowance (DA)</td>
      <td class="amount">{{inr employee.da}}</td>
      <td class="annual">{{inr employee.da_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.conveyance}}
    <tr>
      <td>Conveyance Allowance</td>
      <td class="amount">{{inr employee.conveyance}}</td>
      <td class="annual">{{inr employee.conveyance_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.medical}}
    <tr>
      <td>Medical Allowance</td>
      <td class="amount">{{inr employee.medical}}</td>
      <td class="annual">{{inr employee.medical_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.special_allowance}}
    <tr>
      <td>Special Allowance</td>
      <td class="amount">{{inr employee.special_allowance}}</td>
      <td class="annual">{{inr employee.special_allowance_annual}}</td>
    </tr>
    {{/if}}
    <tr class="gross-row">
      <td><strong>Gross Monthly Earnings (A)</strong></td>
      <td class="amount">{{#if data.gross_earnings}}{{inr data.gross_earnings}}{{else}}{{#if data.gross}}{{inr data.gross}}{{/if}}{{/if}}</td>
      <td class="amount" style="font-weight:700; color:#1e3a8a;">{{#if data.gross_annual}}{{inr data.gross_annual}}{{/if}}</td>
    </tr>
    <!-- Deductions -->
    {{#if employee.pf}}
    <tr class="deduction-row">
      <td>(-) Employee Provident Fund (EPF) &mdash; 12% of Basic</td>
      <td class="amount">{{inr employee.pf}}</td>
      <td class="annual">{{inr employee.pf_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.esi}}
    <tr class="deduction-row">
      <td>(-) Employee State Insurance (ESI)</td>
      <td class="amount">{{inr employee.esi}}</td>
      <td class="annual">{{inr employee.esi_annual}}</td>
    </tr>
    {{/if}}
    {{#if employee.professional_tax}}
    <tr class="deduction-row">
      <td>(-) Professional Tax</td>
      <td class="amount">{{inr employee.professional_tax}}</td>
      <td class="annual">&mdash;</td>
    </tr>
    {{/if}}
    <tr class="net-row">
      <td><strong>Net Monthly Take-Home (B)</strong></td>
      <td class="amount">{{#if data.net_pay}}{{inr data.net_pay}}{{else}}{{#if data.net}}{{inr data.net}}{{/if}}{{/if}}</td>
      <td class="amount" style="color:#93c5fd;">{{#if data.net_annual}}{{inr data.net_annual}}{{/if}}</td>
    </tr>
    <tr class="ctc-row">
      <td><strong>Total Annual CTC</strong></td>
      <td class="amount" colspan="2" style="text-align:right;">
        <strong>&#8377; {{#if employee.offered_ctc}}{{inr employee.offered_ctc}}{{else}}{{inr employee.ctc}}{{/if}} /- per annum</strong>
      </td>
    </tr>
  </table>

  <div class="note-box">
    <strong>Note:</strong> The above compensation is subject to applicable Income Tax (TDS) deductions as per the prevailing Income Tax Act, which will be calculated and deducted based on your declared investments and the applicable tax slab. Net take-home may vary accordingly.
  </div>

  <!-- Benefits -->
  <div class="section-heading">Benefits &amp; Perquisites</div>
  <div class="benefits-box">
    <div class="ben-title">In addition to the above salary components, you will be entitled to the following:</div>
    <table class="ben-table">
      <tr>
        <td>Provident Fund (Company Contribution)</td>
        <td>Gratuity (as per Gratuity Act, on eligibility)</td>
      </tr>
      <tr>
        <td>Annual Performance Bonus (at management discretion)</td>
        <td>ESI Coverage (if applicable by statute)</td>
      </tr>
      <tr>
        <td>Group Mediclaim Insurance</td>
        <td>Professional Development &amp; Training</td>
      </tr>
      <tr>
        <td>Reimbursement of Business Expenses (on approval)</td>
        <td>Annual Salary Review (performance-based)</td>
      </tr>
    </table>
  </div>

  <!-- Leave Policy -->
  <div class="section-heading">Leave Entitlement (Per Calendar Year)</div>
  <table class="leave-table">
    <tr>
      <th>Type of Leave</th>
      <th>Days</th>
      <th>Remarks</th>
    </tr>
    <tr>
      <td>Earned Leave (EL) / Privilege Leave</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">15</td>
      <td>Accrues monthly; carry forward up to 30 days permitted</td>
    </tr>
    <tr>
      <td>Casual Leave (CL)</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">6</td>
      <td>Not carry-forward; not encashable</td>
    </tr>
    <tr>
      <td>Sick Leave (SL) / Medical Leave</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">6</td>
      <td>Medical certificate required for &gt;2 consecutive days</td>
    </tr>
    <tr>
      <td>Maternity Leave</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">26 weeks</td>
      <td>As per Maternity Benefit (Amendment) Act, 2017</td>
    </tr>
    <tr>
      <td>Paternity Leave</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">5</td>
      <td>On birth/legal adoption of a child</td>
    </tr>
    <tr>
      <td>Public / National Holidays</td>
      <td style="text-align:center; font-weight:700; color:#1e40af;">12</td>
      <td>As per company holiday calendar published annually</td>
    </tr>
  </table>

  <p style="font-size:11px; color:#64748b; margin-top:4px;">
    * Leave during probation will be governed by the Company's Leave Policy in force at the time.
    Leaves taken in excess of the entitlement will be treated as Loss of Pay (LOP).
  </p>


<!DOCTYPE html>
<html><head><meta charset="utf-8">
<style>
  body { font-family: 'Segoe UI', Arial, sans-serif; color: #222; font-size: 12px; margin: 0; }
  .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #1e40af; padding-bottom: 10px; margin-bottom: 18px; }
  .header img { max-height: 60px; max-width: 200px; }
  .cinfo { text-align: right; font-size: 10.5px; color: #444; }
  .cinfo .cname { font-size: 15px; font-weight: 700; color: #1e40af; }
  h1.title { text-align: center; font-size: 15px; margin: 8px 0 16px; background: #1e40af; color: #fff; padding: 8px; }
  .meta-table { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
  .meta-table td { border: 1px solid #ccc; padding: 5px 8px; font-size: 11.5px; }
  .meta-table .lbl { background: #f3f4f6; font-weight: 600; width: 22%; }
  table.salary { width: 100%; border-collapse: collapse; margin-top: 10px; }
  table.salary th, table.salary td { border: 1px solid #999; padding: 6px 9px; font-size: 11.5px; }
  table.salary th { background: #1e40af; color: #fff; }
  .text-right { text-align: right; }
  .total-row { background: #f3f4f6; font-weight: 700; }
  .net-row { background: #1e40af; color: #fff; font-weight: 700; font-size: 13px; }
  .signature { margin-top: 35px; display: flex; justify-content: space-between; }
  .signature img { max-height: 50px; }
  .footer { margin-top: 25px; border-top: 1px solid #ccc; padding-top: 5px; text-align: center; font-size: 10px; color: #666; }
  .words { margin-top: 12px; font-style: italic; font-size: 11.5px; }
</style>
</head><body>

<div class="header">
  <div>
    {{#if company.logo_url}}<img src="{{company.logo_url}}" />{{else}}<div style="font-size:18px;font-weight:700;color:#1e40af">{{company.name}}</div>{{/if}}
  </div>
  <div class="cinfo">
    <div class="cname">{{company.name}}</div>
    <div>{{company.address}}{{#if company.city}}, {{company.city}}{{/if}} {{company.pincode}}</div>
    <div>{{company.email}} | {{company.phone}}</div>
  </div>
</div>

<h1 class="title">PAYSLIP FOR {{upper data.pay_month}} {{data.pay_year}}</h1>

<table class="meta-table">
  <tr>
    <td class="lbl">Employee Name</td><td>{{employee.full_name}}</td>
    <td class="lbl">Employee Code</td><td>{{employee.emp_code}}</td>
  </tr>
  <tr>
    <td class="lbl">Designation</td><td>{{employee.designation}}</td>
    <td class="lbl">Department</td><td>{{employee.department}}</td>
  </tr>
  <tr>
    <td class="lbl">Date of Joining</td><td>{{formatDate employee.date_of_joining}}</td>
    <td class="lbl">PAN</td><td>{{employee.pan}}</td>
  </tr>
  <tr>
    <td class="lbl">Bank Name</td><td>{{employee.bank_name}}</td>
    <td class="lbl">Account No.</td><td>{{employee.bank_account}}</td>
  </tr>
  <tr>
    <td class="lbl">UAN</td><td>{{employee.uan}}</td>
    <td class="lbl">PF No.</td><td>{{employee.pf_no}}</td>
  </tr>
  <tr>
    <td class="lbl">Working Days</td><td>{{data.working_days}}</td>
    <td class="lbl">Paid Days</td><td>{{data.paid_days}}</td>
  </tr>
</table>

<table class="salary">
  <tr>
    <th style="width:40%">Earnings</th>
    <th class="text-right" style="width:15%">Amount (₹)</th>
    <th style="width:30%">Deductions</th>
    <th class="text-right" style="width:15%">Amount (₹)</th>
  </tr>
  <tr>
    <td>Basic Salary</td><td class="text-right">{{inr employee.basic}}</td>
    <td>Provident Fund (PF)</td><td class="text-right">{{inr employee.pf}}</td>
  </tr>
  <tr>
    <td>House Rent Allowance (HRA)</td><td class="text-right">{{inr employee.hra}}</td>
    <td>ESI</td><td class="text-right">{{inr employee.esi}}</td>
  </tr>
  <tr>
    <td>Dearness Allowance (DA)</td><td class="text-right">{{inr employee.da}}</td>
    <td>Professional Tax</td><td class="text-right">{{inr employee.professional_tax}}</td>
  </tr>
  <tr>
    <td>Conveyance</td><td class="text-right">{{inr employee.conveyance}}</td>
    <td>TDS</td><td class="text-right">{{inr employee.tds}}</td>
  </tr>
  <tr>
    <td>Medical</td><td class="text-right">{{inr employee.medical}}</td>
    <td>&nbsp;</td><td class="text-right">&nbsp;</td>
  </tr>
  <tr>
    <td>Special Allowance</td><td class="text-right">{{inr employee.special_allowance}}</td>
    <td>&nbsp;</td><td class="text-right">&nbsp;</td>
  </tr>
  <tr class="total-row">
    <td>Total Earnings</td><td class="text-right">₹ {{inr data.gross_earnings}}</td>
    <td>Total Deductions</td><td class="text-right">₹ {{inr data.total_deductions}}</td>
  </tr>
  <tr class="net-row">
    <td colspan="3">NET PAY</td>
    <td class="text-right">₹ {{inr data.net_pay}}</td>
  </tr>
</table>

{{#if data.amount_in_words}}<div class="words"><strong>In Words:</strong> {{data.amount_in_words}}</div>{{/if}}

<div class="signature">
  <div></div>
  <div style="text-align:right">
    {{#if company.signature_url}}<img src="{{company.signature_url}}" /><br/>{{/if}}
    <strong>{{company.signatory_name}}</strong><br/>
    {{company.signatory_designation}}
  </div>
</div>

<div class="footer">This is a computer-generated payslip and does not require a physical signature. | Doc No: {{doc_number}}</div>
</body></html>
